        "retriable_codes": [],
        "fatal_codes": []
      },
      "glm": {
        "business_code_path": "error.code",
        "retriable_codes": ["1200", "1230", "1234", "1302", "1303", "1305", "1312"],
        "fatal_codes": ["1301", "1304", "1308", "1309", "1310", "1311", "1313",
                        "1000", "1001", "1002", "1003", "1004",
                        "1110", "1111", "1112", "1113", "1121"]
      }
    }
  }
}
